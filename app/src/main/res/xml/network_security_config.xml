<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        SECURITY: Cleartext traffic enabled for WebSocket connections.
        Android → WebSocket → kftgcs.com (HTTPS/WSS) → PostgreSQL DB
    -->

    <!-- Base configuration: Allow cleartext traffic for development/testing -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Allow cleartext for local network drone connections.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Production Server Domain -->
        <domain includeSubdomains="true">kftgcs.com</domain>

        <!-- Legacy AWS EC2 Server (for backward compatibility) -->
        <domain includeSubdomains="true">65.0.76.31</domain>

        <!-- Localhost for emulator/local testing -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>

        <!-- Android Emulator host loopback (for WebSocket and API connections) -->
        <domain includeSubdomains="true">10.0.2.2</domain>

        <!-- Private network ranges for drone connections -->
        <!-- Class A private network (10.x.x.x) -->
        <domain includeSubdomains="true">10.0.0.1</domain>
        <domain includeSubdomains="true">10.41.213.197</domain>

        <!-- Class C private network (192.168.x.x) - most common for drones -->
        <domain includeSubdomains="true">192.168.0.1</domain>
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.4.1</domain>

        <!-- Class B private network (172.16.x.x - 172.31.x.x) -->
        <domain includeSubdomains="true">172.16.0.1</domain>
    </domain-config>

    <!-- Debug-only overrides for development/testing -->
    <debug-overrides>
        <trust-anchors>
            <!-- Trust user-installed certificates only in debug builds -->
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>

